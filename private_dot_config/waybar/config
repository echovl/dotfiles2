{
    "layer": "top",
    "position": "top",
    "height": "auto",
    "width": "auto",
    "margin-bottom": -5, // -5 for hyprland
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 0,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window",
        "custom/spotify-prev",
        "custom/spotify-next",
        "custom/spotify"
    ],
    "modules-right": [
        "tray",
        "cpu",
        "memory",
        "network",
        "pulseaudio",
        "backlight",
        "battery"
    ],
    "modules-center": [
        "clock"
    ],
    // Modules configuration
    "sway/workspaces": {
        "format": "{name}",
        "on-click": "activate"
    },
    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate"
    },
    "tray": {
        "icon-size": 20,
        "spacing": 16
    },
    "clock": {
        "interval": 60,
        "format": "{:%A %H:%M}",
        "format-alt": "{:%d %B %Y}",
        "tooltip": false,
        "max-length": 25
    },
    "battery": {
        "bat": "BAT1",
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "{capacity}% ’ā¦",
        "format-icons": [
            "’ēä",
            "’ēā",
            "’ēé",
            "’ēü",
            "’ēĆ"
        ],
        "max-length": 25
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": [
            "’åģ"
        ]
    },
    "pulseaudio": {
        "format": "{icon} {volume}% ",
        "format-bluetooth": "{icon}’Ŗö {volume}%",
        "format-muted": "’Ć” 0%",
        "format-icons": {
            "headphone": "’Ćź",
            "hands-free": "’¢É",
            "headset": "’¢É",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": [
                "’Ć¦",
                "’Ć©"
            ]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol",
        "ignored-sinks": [
            "Easy Effects Sink"
        ]
    },
    "sway/window": {
        "format": "{app_id}",
        "max-length": 50,
        "separate-outputs": true
    },
    "hyprland/window": {
        "format": "{class}",
        "max-length": 50,
        "separate-outputs": true
    },
    "cpu": {
        "interval": 5,
        "format": "’ŗø {usage}%",
        "tooltip": true,
        "max-length": 10
    },
    "memory": {
        "interval": 5,
        "format": "’öĖ {percentage}%",
        "tooltip": true,
        "tooltip-format": "{used:0.1f}GiB / {total:0.1f}GiB",
        "max-length": 10
    },
    "network": {
        "interface": "wlan0",
        "format": "{ifname}",
        "format-wifi": "’ć½ {signalStrength}%",
        "format-ethernet": "¾░ŖŚ {ipaddr}/{cidr}",
        "format-disconnected": "", //An empty format will hide the module.
        "tooltip-format": "¾░ŖŚ {ifname} via {gwaddr}",
        "tooltip-format-wifi": "’ć½ {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "{ifname} ’āü",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50
    },
    "custom/spotify": {
        "format": "{}",
        "max-length": 25,
        "tooltip": true,
        "exec": "python ~/.local/bin/spotify_status.py",
        "exec-if": "pgrep spotify",
        "interval": 1,
        "on-click": "playerctl -p spotify play-pause"
    },
    "custom/spotify-prev": {
        "format": "{}",
        "tooltip": true,
        "tooltip-format": "Previous Track",
        "exec": "echo ’üł",
        "on-click": "playerctl -p spotify previous",
        "interval": 1,
        "exec-if": "pgrep spotify"
    },
    "custom/spotify-next": {
        "format": "{}",
        "tooltip": true,
        "tooltip-format": "Next Track",
        "on-click": "playerctl -p spotify next",
        "interval": 1,
        "exec": "echo ’üæ",
        "exec-if": "pgrep spotify"
    }
}
